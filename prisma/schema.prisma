generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// USER & AUTH
// ─────────────────────────────────────────

model User {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  username        String    @unique
  email           String    @unique
  passwordHash    String?
  avatarUrl       String?   // DiceBear URL or custom
  avatarFrameId   String?   @db.ObjectId
  bio             String?

  // Progression
  level           Int       @default(1)
  xp              Int       @default(0)
  coins           Int       @default(100)       // new users start with 100 coins
  rankedPoints    Int       @default(0)

  // Stats
  totalWins       Int       @default(0)
  totalMatches    Int       @default(0)
  longestStreak   Int       @default(0)

  // Daily Login
  loginStreak     Int       @default(0)
  lastLoginDate   DateTime?
  lastSpinDate    DateTime?

  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  matchesAsP1       Match[]              @relation("Player1Matches")
  matchesAsP2       Match[]              @relation("Player2Matches")
  purchases         Purchase[]
  weeklyStats       WeeklyStats[]
  dailyCompletions  DailyQuizCompletion[]
  tournamentEntries TournamentEntry[]
  accounts          Account[]
  sessions          Session[]
  notifications     Notification[]
  generalProgress   GeneralProgress[]
}

// ─────────────────────────────────────────
// NEXTAUTH MODELS (required by @auth/prisma-adapter)
// ─────────────────────────────────────────

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────
// QUESTIONS
// ─────────────────────────────────────────

model Question {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  text        String
  options     String[] // 4 answer options
  answerIndex Int      // 0–3 (index of correct answer in options)
  category    String   // "general" | "science" | "history" | "sports" | "entertainment"
  difficulty  String   // "easy" | "medium" | "hard"
  explanation String?  // optional explanation shown after answer
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// ─────────────────────────────────────────
// MATCHES (1v1, Daily, Tournament Round)
// ─────────────────────────────────────────

model Match {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  type         String    // "casual" | "ranked" | "coin_bet" | "daily" | "tournament"
  status       String    @default("pending") // "pending" | "active" | "completed" | "abandoned"

  player1Id    String    @db.ObjectId
  player2Id    String?   @db.ObjectId         // null for daily quiz
  winnerId     String?   @db.ObjectId

  player1Score Int       @default(0)
  player2Score Int       @default(0)

  coinStake    Int       @default(0)          // for coin_bet mode
  questionIds  String[]  @db.ObjectId         // ordered list of 10 question IDs

  tournamentId String?   @db.ObjectId
  roundNumber  Int?                            // tournament round

  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  player1      User      @relation("Player1Matches", fields: [player1Id], references: [id])
  player2      User?     @relation("Player2Matches", fields: [player2Id], references: [id])
  tournament   Tournament? @relation(fields: [tournamentId], references: [id])
}

// ─────────────────────────────────────────
// TOURNAMENTS
// ─────────────────────────────────────────

model Tournament {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  entryFee    Int       @default(100)
  prizePool   Int       @default(0)
  maxPlayers  Int       @default(16)
  status      String    @default("open") // "open" | "active" | "completed"
  bracket     Json?     // bracket structure stored as JSON
  winnerId    String?   @db.ObjectId
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  entries     TournamentEntry[]
  matches     Match[]
}

model TournamentEntry {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  tournamentId String     @db.ObjectId
  userId       String     @db.ObjectId
  joinedAt     DateTime   @default(now())
  eliminated   Boolean    @default(false)
  placement    Int?       // final placement (1st, 2nd, etc.)

  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@unique([tournamentId, userId])
}

// ─────────────────────────────────────────
// SHOP & PURCHASES
// ─────────────────────────────────────────

model ShopItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  type        String   // "avatar" | "frame" | "theme" | "xp_boost" | "coin_doubler"
  imageUrl    String?
  cost        Int
  rarity      String   @default("common") // "common" | "rare" | "epic" | "legendary"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Purchase {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  itemId      String   @db.ObjectId
  purchasedAt DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}

// ─────────────────────────────────────────
// DAILY QUIZ
// ─────────────────────────────────────────

model DailyQuizCompletion {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  date        String   // "YYYY-MM-DD" format for easy querying
  score       Int
  totalQ      Int      @default(10)
  coinsEarned Int      @default(0)
  xpEarned    Int      @default(0)
  completedAt DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

// ─────────────────────────────────────────
// LEADERBOARD / WEEKLY STATS
// ─────────────────────────────────────────

model WeeklyStats {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  weekStart String   // "YYYY-MM-DD" of the Monday that week started
  wins      Int      @default(0)
  matches   Int      @default(0)
  points    Int      @default(0)

  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, weekStart])
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  title     String
  message   String
  type      String   // "rank" | "rewards" | "battle" | "tournament"
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

// ─────────────────────────────────────────
// GENERAL LEVEL PROGRESS SYSTEM
// ─────────────────────────────────────────

model GeneralProgress {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  category      String   // "world" | "science" | "computer" | "pharmacy" | "mixed"
  unlockedLevel Int      @default(1) // Tracks current highest unlocked level (e.g. 1 to 200)
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id])

  @@unique([userId, category])
}